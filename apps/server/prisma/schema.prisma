generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("users")
}

model LlmChatCall {
  id              Int       @id @default(autoincrement())
  requestId       String    @unique(map: "llm_chat_call_request_id_uq") @map("request_id")
  provider        String
  model           String
  status          String
  requestPayload  Json      @map("request_payload") @db.JsonB
  responsePayload Json?     @map("response_payload") @db.JsonB
  error           Json?     @db.JsonB
  latencyMs       Int?      @map("latency_ms")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([provider, model], map: "llm_chat_call_provider_model_idx")
  @@index([createdAt], map: "llm_chat_call_created_at_idx")
  @@map("llm_chat_call")
}

model AppLog {
  id        Int      @id @default(autoincrement())
  traceId   String   @map("trace_id")
  level     String
  message   String
  metadata  Json     @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([traceId, createdAt], map: "app_log_trace_id_created_at_idx")
  @@index([level, createdAt], map: "app_log_level_created_at_idx")
  @@index([createdAt], map: "app_log_created_at_idx")
  @@map("app_log")
}
