generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LlmChatCall {
  id              Int       @id @default(autoincrement())
  requestId       String    @map("request_id")
  loopRunId       String?   @map("loop_run_id")
  seq             Int       @default(1)
  provider        String
  model           String
  extension       Json?     @db.JsonB
  status          String
  requestPayload  Json      @map("request_payload") @db.JsonB
  responsePayload Json?     @map("response_payload") @db.JsonB
  nativeRequestPayload  Json?     @map("native_request_payload") @db.JsonB
  nativeResponsePayload Json?     @map("native_response_payload") @db.JsonB
  error           Json?     @db.JsonB
  nativeError     Json?     @map("native_error") @db.JsonB
  latencyMs       Int?      @map("latency_ms")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([requestId, seq], map: "llm_chat_call_request_id_seq_uq")
  @@index([loopRunId], map: "llm_chat_call_loop_run_id_idx")
  @@index([provider, model], map: "llm_chat_call_provider_model_idx")
  @@index([createdAt], map: "llm_chat_call_created_at_idx")
  @@map("llm_chat_call")
}

model LoopRun {
  id               String        @id
  groupId          String        @map("group_id")
  triggerMessageId Int?          @map("trigger_message_id")
  status           String
  triggerPayload   Json          @map("trigger_payload") @db.JsonB
  startedAt        DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt       DateTime?     @map("finished_at") @db.Timestamptz(6)
  durationMs       Int?          @map("duration_ms")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  steps            LoopRunStep[]

  @@index([groupId, createdAt], map: "loop_run_group_id_created_at_idx")
  @@index([createdAt], map: "loop_run_created_at_idx")
  @@map("loop_run")
}

model LoopRunStep {
  id         Int      @id @default(autoincrement())
  loopRunId  String   @map("loop_run_id")
  seq        Int
  type       String
  title      String
  status     String
  payload    Json     @db.JsonB
  startedAt  DateTime @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt DateTime? @map("finished_at") @db.Timestamptz(6)
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  loopRun    LoopRun  @relation(fields: [loopRunId], references: [id], onDelete: Cascade)

  @@unique([loopRunId, seq], map: "loop_run_step_loop_run_id_seq_uq")
  @@index([loopRunId, createdAt], map: "loop_run_step_loop_run_id_created_at_idx")
  @@map("loop_run_step")
}

model EmbeddingCache {
  id                  Int      @id @default(autoincrement())
  provider            String
  model               String
  taskType            String   @map("task_type")
  outputDimensionality Int     @map("output_dimensionality")
  text                String
  textHash            String   @map("text_hash")
  embedding           Float[]
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([provider, model, taskType, outputDimensionality, textHash], map: "embedding_cache_provider_model_task_output_text_hash_uq")
  @@index([createdAt], map: "embedding_cache_created_at_idx")
  @@map("embedding_cache")
}

model AppLog {
  id        Int      @id @default(autoincrement())
  traceId   String   @map("trace_id")
  level     String
  message   String
  metadata  Json     @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([traceId, createdAt], map: "app_log_trace_id_created_at_idx")
  @@index([level, createdAt], map: "app_log_level_created_at_idx")
  @@index([createdAt], map: "app_log_created_at_idx")
  @@map("app_log")
}

model NapcatEvent {
  id          Int       @id @default(autoincrement())
  postType    String    @map("post_type")
  messageType String?   @map("message_type")
  subType     String?   @map("sub_type")
  userId      String?   @map("user_id")
  groupId     String?   @map("group_id")
  rawMessage  String?   @map("raw_message")
  eventTime   DateTime? @map("event_time") @db.Timestamptz(6)
  payload     Json      @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "napcat_event_created_at_idx")
  @@index([postType, createdAt], map: "napcat_event_post_type_created_at_idx")
  @@index([messageType, createdAt], map: "napcat_event_message_type_created_at_idx")
  @@index([userId, createdAt], map: "napcat_event_user_id_created_at_idx")
  @@map("napcat_event")
}

model NapcatGroupMessage {
  id         Int       @id @default(autoincrement())
  groupId    String    @map("group_id")
  userId     String?   @map("user_id")
  nickname   String?
  messageId  Int?      @map("message_id")
  message    Json      @db.JsonB
  eventTime  DateTime? @map("event_time") @db.Timestamptz(6)
  payload    Json      @db.JsonB
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  chunks     NapcatGroupMessageChunk[]

  @@index([createdAt], map: "napcat_group_message_created_at_idx")
  @@index([groupId, createdAt], map: "napcat_group_message_group_id_created_at_idx")
  @@index([nickname, createdAt], map: "napcat_group_message_nickname_created_at_idx")
  @@index([userId, createdAt], map: "napcat_group_message_user_id_created_at_idx")
  @@map("napcat_group_message")
}

model NapcatGroupMessageChunk {
  id              Int                @id @default(autoincrement())
  sourceMessageId Int                @map("source_message_id")
  groupId         String             @map("group_id")
  chunkIndex      Int                @default(0) @map("chunk_index")
  content         String
  status          String
  embeddingModel  String?            @map("embedding_model")
  embeddingDim    Int?               @map("embedding_dim")
  embedding       Unsupported("vector(768)")?
  errorMessage    String?            @map("error_message")
  indexedAt       DateTime?          @map("indexed_at") @db.Timestamptz(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  sourceMessage   NapcatGroupMessage @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)

  @@unique([sourceMessageId, chunkIndex], map: "napcat_group_message_chunk_source_chunk_idx_uq")
  @@index([groupId, status, createdAt], map: "napcat_group_message_chunk_group_status_created_at_idx")
  @@index([sourceMessageId], map: "napcat_group_message_chunk_source_message_id_idx")
  @@map("napcat_group_message_chunk")
}

model CodexAuthSession {
  id            Int      @id @default(autoincrement())
  provider      String
  accountId     String?  @map("account_id")
  email         String?
  accessToken   String?  @map("access_token")
  refreshToken  String?  @map("refresh_token")
  idToken       String?  @map("id_token")
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz(6)
  lastRefreshAt DateTime? @map("last_refresh_at") @db.Timestamptz(6)
  status        String
  lastError     String?  @map("last_error")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([provider], map: "codex_auth_session_provider_uq")
  @@index([status, updatedAt], map: "codex_auth_session_status_updated_at_idx")
  @@map("codex_auth_session")
}

model CodexOAuthState {
  id          Int       @id @default(autoincrement())
  state       String    @unique(map: "codex_oauth_state_state_uq")
  codeVerifier String   @map("code_verifier")
  redirectUri String    @map("redirect_uri")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt      DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "codex_oauth_state_expires_at_idx")
  @@map("codex_oauth_state")
}

model ClaudeCodeAuthSession {
  id            Int       @id @default(autoincrement())
  provider      String
  accountId     String?   @map("account_id")
  email         String?
  accessToken   String?   @map("access_token")
  refreshToken  String?   @map("refresh_token")
  idToken       String?   @map("id_token")
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz(6)
  lastRefreshAt DateTime? @map("last_refresh_at") @db.Timestamptz(6)
  status        String
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([provider], map: "claude_code_auth_session_provider_uq")
  @@index([status, updatedAt], map: "claude_code_auth_session_status_updated_at_idx")
  @@map("claude_code_auth_session")
}

model ClaudeCodeOAuthState {
  id           Int       @id @default(autoincrement())
  state        String    @unique(map: "claude_code_oauth_state_state_uq")
  codeVerifier String    @map("code_verifier")
  redirectUri  String    @map("redirect_uri")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "claude_code_oauth_state_expires_at_idx")
  @@map("claude_code_oauth_state")
}
