{
  "name": "@kagami/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json && node scripts/copy-static.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "db:generate": "bash ../../scripts/prisma.sh generate",
    "db:migrate:dev": "bash ../../scripts/prisma.sh migrate dev",
    "db:migrate:deploy": "bash ../../scripts/prisma.sh migrate deploy",
    "db:migrate:status": "bash ../../scripts/prisma.sh migrate status",
    "db:migrate:reset": "bash ../../scripts/prisma.sh migrate reset",
    "db:migrate:resolve": "bash ../../scripts/prisma.sh migrate resolve"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@kagami/agent-runtime": "workspace:*",
    "@kagami/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "fastify": "^5.6.2",
    "handlebars": "^4.7.8",
    "openai": "^6.25.0",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
