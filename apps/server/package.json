{
  "name": "@kagami/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json && node scripts/copy-agent-prompts.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "db:generate": "sh -lc 'if [ -z \"${DATABASE_URL:-}\" ] && [ -f ../../.env ]; then set -a; . ../../.env; set +a; fi; pnpm exec prisma generate'",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:resolve": "prisma migrate resolve"
  },
  "dependencies": {
    "@kagami/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "fastify": "^5.6.2",
    "openai": "^6.25.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
