{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "paths": {
      "@kagami/kernel/*": ["./../../packages/kernel/src/*"],
      "@kagami/http/*": ["./../../packages/http/src/*"],
      "@kagami/napcat-api/*": ["./../../packages/napcat-api/src/*"],
      "@kagami/llm-api/*": ["./../../packages/llm-api/src/*"],
      "@kagami/llm-client": ["./../../packages/llm-client/src/index.ts"],
      "@kagami/oss-api/*": ["./../../packages/oss-api/src/*"],
      "@kagami/rpc-client/*": ["./../../packages/rpc-client/src/*"]
    }
  },
  "include": ["src", "test"]
}
