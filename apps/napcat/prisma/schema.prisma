generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "sqlite"
}

// napcat 独占的 SQLite 库（epic #539 子 issue 2，与主库 kagami.db 物理分离）。
// 四张表从 packages/persistence 的共享 schema 原样搬入（表名 / 列名 / 索引名不变）。
// 历史数据搬迁与主库旧表 DROP 均已完成（#539 子 issue 5），本库是这些表的唯一归属。

// NapCat 入站原始事件审计（console 查询用）。
model NapcatEvent {
  id          Int       @id @default(autoincrement())
  postType    String    @map("post_type")
  messageType String?   @map("message_type")
  subType     String?   @map("sub_type")
  userId      String?   @map("user_id")
  groupId     String?   @map("group_id")
  eventTime   DateTime? @map("event_time")
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([createdAt], map: "napcat_event_created_at_idx")
  @@index([postType, createdAt], map: "napcat_event_post_type_created_at_idx")
  @@index([messageType, createdAt], map: "napcat_event_message_type_created_at_idx")
  @@index([userId, createdAt], map: "napcat_event_user_id_created_at_idx")
  @@map("napcat_event")
}

// QQ 消息结构化落库（console 查询 + 群消息上下文窗口用）。
model NapcatQqMessage {
  id          Int       @id @default(autoincrement())
  messageType String    @map("message_type")
  subType     String    @map("sub_type")
  groupId     String?   @map("group_id")
  userId      String?   @map("user_id")
  nickname    String?
  messageId   Int?      @map("message_id")
  message     Json
  eventTime   DateTime? @map("event_time")
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([createdAt], map: "napcat_qq_message_created_at_idx")
  @@index([messageType, createdAt], map: "napcat_qq_message_message_type_created_at_idx")
  @@index([groupId, createdAt], map: "napcat_qq_message_group_id_created_at_idx")
  @@index([nickname, createdAt], map: "napcat_qq_message_nickname_created_at_idx")
  @@index([userId, createdAt], map: "napcat_qq_message_user_id_created_at_idx")
  @@map("napcat_qq_message")
}

// napcat 服务对 agent 的入站事件 outbox（issue #347）。每条 = 一个渲染好的 agent-facing
// NapcatAgentEvent，单调 seq 即 SSE event id。napcat 先事务落这里拿 seq 再推 SSE，agent 重连带
// Last-Event-ID 回放 seq> 缺口、按 seq 去重（严格 at-least-once）。createdAt 索引 + 定期 prune >7d。
model NapcatEventOutbox {
  seq       Int      @id @default(autoincrement())
  event     Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt], map: "napcat_event_outbox_created_at_idx")
  @@map("napcat_event_outbox")
}

// QQ 图片资产（file-id = 内容 MD5 内容寻址；resid 指向 OSS，description 为 vision 描述）。
model ImageAsset {
  id          Int      @id @default(autoincrement())
  fileId      String   @unique(map: "image_asset_file_id_uq") @map("file_id")
  resid       String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("image_asset")
}
