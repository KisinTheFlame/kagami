    "pngjs": "^7.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
