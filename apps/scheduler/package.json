{
  "name": "@kagami/scheduler-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "pretest": "pnpm --filter \"@kagami/scheduler-service^...\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "start": "node dist/index.js",
    "db:generate": "PRISMA_PACKAGE_DIR=apps/scheduler PRISMA_CONFIG_KEY=services.scheduler.databaseUrl bash ../../scripts/prisma.sh generate",
    "db:migrate:dev": "PRISMA_PACKAGE_DIR=apps/scheduler PRISMA_CONFIG_KEY=services.scheduler.databaseUrl bash ../../scripts/prisma.sh migrate dev",
    "db:migrate:deploy": "PRISMA_PACKAGE_DIR=apps/scheduler PRISMA_CONFIG_KEY=services.scheduler.databaseUrl bash ../../scripts/prisma.sh migrate deploy",
    "db:migrate:status": "PRISMA_PACKAGE_DIR=apps/scheduler PRISMA_CONFIG_KEY=services.scheduler.databaseUrl bash ../../scripts/prisma.sh migrate status"
  },
  "dependencies": {
    "@kagami/http": "workspace:*",
    "@kagami/kernel": "workspace:*",
    "@kagami/rpc-client": "workspace:*",
    "@kagami/scheduler-api": "workspace:*",
    "@prisma/adapter-better-sqlite3": "7.6.0",
    "@prisma/client": "7.6.0",
    "better-sqlite3": "^12.11.1",
    "croner": "^10.0.1",
    "fastify": "^5.6.2",
    "prisma": "7.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
