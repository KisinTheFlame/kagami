{
  "name": "@kagami/llm-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "pretest": "pnpm --filter \"@kagami/llm-service^...\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "start": "node dist/index.js",
    "db:generate": "PRISMA_PACKAGE_DIR=apps/llm PRISMA_CONFIG_KEY=services.llm.databaseUrl bash ../../scripts/prisma.sh generate",
    "db:migrate:dev": "PRISMA_PACKAGE_DIR=apps/llm PRISMA_CONFIG_KEY=services.llm.databaseUrl bash ../../scripts/prisma.sh migrate dev",
    "db:migrate:deploy": "PRISMA_PACKAGE_DIR=apps/llm PRISMA_CONFIG_KEY=services.llm.databaseUrl bash ../../scripts/prisma.sh migrate deploy",
    "db:migrate:status": "PRISMA_PACKAGE_DIR=apps/llm PRISMA_CONFIG_KEY=services.llm.databaseUrl bash ../../scripts/prisma.sh migrate status"
  },
  "dependencies": {
    "@kagami/auth": "workspace:*",
    "@kagami/http": "workspace:*",
    "@kagami/kernel": "workspace:*",
    "@kagami/llm": "workspace:*",
    "@kagami/llm-api": "workspace:*",
    "@kagami/llm-client": "workspace:*",
    "@kagami/metric-client": "workspace:*",
    "@kagami/scheduler-client": "workspace:*",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "fastify": "^5.6.2",
    "prisma": "^7.6.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
