{
  "name": "@kagami/browser",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pretest": "pnpm --filter \"@kagami/browser^...\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@kagami/browser-api": "workspace:*",
    "@kagami/http": "workspace:*",
    "@kagami/kernel": "workspace:*",
    "cloakbrowser": "^0.4.3",
    "fastify": "^5.6.2",
    "playwright-core": "^1.61.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
