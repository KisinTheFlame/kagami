{
  "name": "@kagami/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-static.mjs",
    "pretest": "pnpm --filter \"@kagami/agent^...\" build",
    "test": "NODE_OPTIONS=--max-old-space-size=2048 vitest run",
    "test:watch": "NODE_OPTIONS=--max-old-space-size=2048 vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kagami/agent-api": "workspace:*",
    "@kagami/agent-runtime": "workspace:*",
    "@kagami/browser-api": "workspace:*",
    "@kagami/http": "workspace:*",
    "@kagami/kernel": "workspace:*",
    "@kagami/llm": "workspace:*",
    "@kagami/llm-api": "workspace:*",
    "@kagami/llm-client": "workspace:*",
    "@kagami/metric-api": "workspace:*",
    "@kagami/metric-client": "workspace:*",
    "@kagami/napcat-api": "workspace:*",
    "@kagami/oss-api": "workspace:*",
    "@kagami/persistence": "workspace:*",
    "@kagami/pixel-api": "workspace:*",
    "@kagami/rpc-client": "workspace:*",
    "@kagami/spire-api": "workspace:*",
    "cloakbrowser": "^0.4.3",
    "croner": "^10.0.1",
    "fast-xml-parser": "^5.5.9",
    "fastify": "^5.6.2",
    "handlebars": "^4.7.8",
    "hnswlib-node": "^3.0.0",
    "node-html-parser": "^7.1.0",
    "playwright-core": "^1.61.1",
    "yaml": "^2.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
