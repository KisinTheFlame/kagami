{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "paths": {
      "@kagami/agent-runtime": ["./../../packages/agent-runtime/src/index.ts"],
      "@kagami/agent-runtime/*": ["./../../packages/agent-runtime/src/*"],
      "@kagami/llm": ["./../../packages/llm/src/index.ts"],
      "@kagami/llm-client": ["./../../packages/llm-client/src/index.ts"],
      "@kagami/llm-client/embedding": ["./../../packages/llm-client/src/embedding/index.ts"],
      "@kagami/persistence/prisma": [
        "./../../packages/persistence/src/generated/prisma/internal/prismaNamespace.ts"
      ],
      "@kagami/persistence/*": ["./../../packages/persistence/src/*"],
      "@kagami/kernel/*": ["./../../packages/kernel/src/*"],
      "@kagami/http/*": ["./../../packages/http/src/*"],
      "@kagami/llm-api/*": ["./../../packages/llm-api/src/*"],
      "@kagami/browser-api/*": ["./../../packages/browser-api/src/*"],
      "@kagami/oss-api/*": ["./../../packages/oss-api/src/*"],
      "@kagami/spire-api/*": ["./../../packages/spire-api/src/*"],
      "@kagami/pixel-api/*": ["./../../packages/pixel-api/src/*"],
      "@kagami/rpc-client/*": ["./../../packages/rpc-client/src/*"],
      "@kagami/metric-api/*": ["./../../packages/metric-api/src/*"],
      "@kagami/agent-api/*": ["./../../packages/agent-api/src/*"]
    }
  },
  "include": ["src", "test"]
}
