server:
  databaseUrl: file:./data/sqlite/kagami.db # SQLite 库文件，相对仓库根；运行时与 Prisma CLI 解析为绝对路径
  port: 20003
  agent:
    contextCompactionTotalTokenThreshold: 150000
    llmRetryBackoffMs: 30000
    waitToolMaxWaitMs: 600000
    notificationBatchWindowMs: 30000
    story:
      enabled: true # 是否启用 Story Agent（后台故事写作 loop）；置 false 则不运行后台 loop，也不消费 ledger 事件
      batchSize: 24
      idleFlushMs: 120000
      memory:
        embedding:
          provider: tei-embedding-gemma
          baseUrl: http://127.0.0.1:20008
          model: google/embeddinggemma-300m
          outputDimensionality: 768
        vectorIndexPath: ./data/vector/story-memory.hnsw # HNSW 向量索引文件（派生缓存，缺失时从 SQLite 重建）
        retrieval:
          topK: 3
      recall:
        enabled: true # 是否开启 Story Recall Agent（后台自动召回历史故事并注入上下文）
        topK: 2
        scoreThreshold: 0.65
    messaging:
      aiTone:
        enabled: true # 发言 AI 味门控；置 false 完全退化为原发送行为
        blockThreshold: 0.8 # P(AI) >= 该值则拦下不发，等 confirm_last 二次确认
  ithome:
    pollIntervalMs: 300000
    recentArticleLimit: 8
    articleMaxChars: 8000
  napcat:
    wsUrl: ws://localhost:6099
    reconnectMs: 3000
    requestTimeoutMs: 10000
    listenGroupIds:
      - "123456"
    startupContextRecentMessageCount: 40
  llm:
    timeoutMs: 45000
    authUsageRefreshIntervalMs: 600000
    codexAuth:
      enabled: true
      publicBaseUrl: http://localhost:20004
      oauthRedirectPath: /auth/callback
      oauthStateTtlMs: 600000
      refreshLeewayMs: 60000
      refreshCheckIntervalMs: 60000
      binaryPath: codex
    claudeCodeAuth:
      enabled: true
      publicBaseUrl: http://localhost:20004
      oauthRedirectPath: /callback
      oauthStateTtlMs: 600000
      refreshLeewayMs: 7200000
      refreshCheckIntervalMs: 300000
    providers:
      deepseek:
        apiKey: ""
        baseUrl: https://api.deepseek.com
        models:
          - deepseek-chat
      openai:
        apiKey: ""
        baseUrl: https://api.openai.com/v1
        models:
          - gpt-4o-mini
      openaiCodex:
        baseUrl: https://chatgpt.com/backend-api/codex/responses
        models:
          - gpt-5.3-codex
      claudeCode:
        baseUrl: https://api.anthropic.com
        models:
          - claude-sonnet-4-6
        keepAliveReplayIntervalMinutes: 30
    usages:
      agent:
        attempts:
          - provider: claude-code
            model: claude-sonnet-4-6
          - provider: openai-codex
            model: gpt-5.4
            times: 2
      storyAgent:
        attempts:
          - provider: claude-code
            model: claude-haiku-4-5
      contextSummarizer:
        attempts:
          - provider: openai
            model: gpt-4o-mini
      vision:
        attempts:
          - provider: openai
            model: gpt-4o-mini
      webSearchAgent:
        attempts:
          - provider: openai
            model: gpt-4o-mini
  tavily:
    apiKey: ""
  bot:
    qq: "10001"
    creator:
      name: "创造者"
      qq: "10000"
  # 自建对象存储（@kagami/oss）的访问地址，给 server 把 QQ 图片原图 PUT 进去存档用。
  # 整段可省略 → 关闭图片存档（resid 恒为 null，只走 vision 文字描述，优雅降级）。
  oss:
    baseUrl: http://127.0.0.1:20005 # 指向下方独立 oss 进程监听的端口
  # 每个 App 的配置切片。key 是 App.id，结构由各 App 自己的 configSchema 校验。
  # 没列出来的 App 走 schema 默认值；schema 不接受的字段会在启动时报错。
  apps:
    calc:
      # 计算结果保留的小数位数（0–20）。省略 / null 表示不做四舍五入。
      precision: 6
    terminal:
      # 终端 App。小镜的"家"默认在 ~/kagami/（由 os.homedir() 解析）。
      # initialCwd: ~/kagami         # 可选；不填则使用 os.homedir() + "/kagami"
      commandTimeoutMs: 60000        # 单条命令超时，超时后进程组被强杀，partial 输出仍保留
      previewBytes: 2048             # 工具返回的 stdout/stderr preview 上限，每条独立
      maxOutputBytes: 1048576        # 单条命令完整捕获上限（1 MB），超过后停止接收
      maxCommandLength: 4096         # command 参数字符长度上限
      readOutputMaxSize: 4096        # read_bash_output 单次返回字节上限
      shell: /bin/sh                 # 执行 bash command 时使用的 shell
    hn:
      # Hacker News App（只读：逛 / 读讨论 / 搜 / 看用户）。两个 API 都零鉴权公开。
      # 整段可省略，全部字段都有默认值。
      userAgent: "Mozilla/5.0 ... Kagami/1.0"  # 请求 HN 用的 User-Agent
      fetchTimeoutMs: 10000          # 单次 HTTP 超时
      fetchMaxAttempts: 3            # 含首次的最大尝试次数（只对 429/408/5xx/网络错误重试）
      fetchBackoffBaseMs: 500        # 指数退避基数
      fetchBackoffMaxMs: 8000        # 退避上限
      glanceDefaultLimit: 15         # glance_hn 默认看几条
      glanceLimitCap: 30             # glance_hn 上限（超过被截断）
      glanceConcurrency: 6           # glance_hn 拉 item 的并发上限
      commentTopLimit: 20            # open_hn_thread 展开的主楼评论数
      commentReplyLimit: 3           # 每条主楼展开的第一层回复数
      perCommentMaxChars: 600        # 单条评论 / 片段最大字符
      responseMaxChars: 8000         # open_hn_thread 评论总字符预算，超出截断
      searchHitsLimit: 15            # search_hn 返回命中数
      userActivityLimit: 10          # open_hn_user 近期发言条数

# 自建对象存储服务（@kagami/oss，独立进程）。其余实现细节（db/blob 路径、body 上限）是代码常量。
oss:
  port: 20005 # 仅此一项可调：localhost HTTP 监听端口，避开 server 20003 / web 20004
