# 隐私配置模板（密钥 + PII）。本文件是模板；请 `cp config.secret.yaml.example config.secret.yaml`
# 后填真实值。config.secret.yaml 被 git ignore，绝不提交。
#
# 结构与 config.yaml 同构，只放隐私叶子；启动时深合并进 config.yaml（同名键 secret 优先，
# 数组整体替换）。可覆盖任意字段（不再有隐私路径白名单）；约定上只往这里放凭据 / PII，
# 拓扑（services.* / server.databaseUrl 等）仍应留在 config.yaml。
server:
  napcat:
    # napcat WS 地址。内嵌的 access_token 是凭据，故整条 wsUrl 放这里（config.yaml 不含）。
    wsUrl: "ws://localhost:6099/?access_token=your-napcat-token"
    # 监听的 QQ 群号（PII）。数组会整体覆盖 config.yaml，不做拼接。
    listenGroupIds:
      - "123456"
  llm:
    providers:
      deepseek:
        apiKey: "" # 可留空（不启用 deepseek 时）
      openai:
        apiKey: "" # 可留空
  tavily:
    apiKey: "" # 必填：Tavily 搜索 API key
  bot:
    qq: "10001" # 机器人自身 QQ
    creator:
      name: "创造者"
      qq: "10000" # 创造者 QQ
  # 仅当 story.memory.embedding 使用 google provider 时才需要（默认的 tei-embedding-gemma 不需要）：
  # agent:
  #   story:
  #     memory:
  #       embedding:
  #         apiKey: "" # google gemini embedding key
  # App 级凭据（按需填，省略即不启用对应能力）：
  apps:
    amap:
      apiKey: "" # 高德 Web 服务 API key（填了才启用高德地图 App；留空=优雅降级不可用）
    # browser:
    #   proxy: "<代理 URL，可含 user:pass@host:port>"
    #   licenseKey: "" # CloakBrowser Pro license
