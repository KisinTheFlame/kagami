generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "sqlite"
}

model LlmChatCall {
  id                    Int      @id @default(autoincrement())
  requestId             String   @map("request_id")
  seq                   Int      @default(1)
  provider              String
  model                 String
  extension             Json?
  status                String
  requestPayload        Json     @map("request_payload")
  responsePayload       Json?    @map("response_payload")
  nativeRequestPayload  Json?    @map("native_request_payload")
  nativeResponsePayload Json?    @map("native_response_payload")
  error                 Json?
  nativeError           Json?    @map("native_error")
  latencyMs             Int?     @map("latency_ms")
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([requestId, seq], map: "llm_chat_call_request_id_seq_uq")
  @@index([provider, model], map: "llm_chat_call_provider_model_idx")
  @@index([createdAt], map: "llm_chat_call_created_at_idx")
  @@map("llm_chat_call")
}

model AppLog {
  id        Int      @id @default(autoincrement())
  traceId   String   @map("trace_id")
  level     String
  message   String
  metadata  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([traceId, createdAt], map: "app_log_trace_id_created_at_idx")
  @@index([level, createdAt], map: "app_log_level_created_at_idx")
  @@index([createdAt], map: "app_log_created_at_idx")
  @@map("app_log")
}

model Metric {
  id         Int      @id @default(autoincrement())
  metricName String   @map("metric_name")
  value      Float
  tags       Json
  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([metricName, occurredAt], map: "metric_metric_name_occurred_at_idx")
  @@index([createdAt], map: "metric_created_at_idx")
  @@map("metric")
}

model MetricChart {
  id         Int      @id @default(autoincrement())
  chartName  String   @unique(map: "metric_chart_chart_name_uq") @map("chart_name")
  metricName String   @map("metric_name")
  aggregator String
  tagFilters Json?    @map("tag_filters")
  groupByTag String?  @map("group_by_tag")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@map("metric_chart")
}

model NapcatEvent {
  id          Int       @id @default(autoincrement())
  postType    String    @map("post_type")
  messageType String?   @map("message_type")
  subType     String?   @map("sub_type")
  userId      String?   @map("user_id")
  groupId     String?   @map("group_id")
  eventTime   DateTime? @map("event_time")
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([createdAt], map: "napcat_event_created_at_idx")
  @@index([postType, createdAt], map: "napcat_event_post_type_created_at_idx")
  @@index([messageType, createdAt], map: "napcat_event_message_type_created_at_idx")
  @@index([userId, createdAt], map: "napcat_event_user_id_created_at_idx")
  @@map("napcat_event")
}

model NapcatQqMessage {
  id          Int       @id @default(autoincrement())
  messageType String    @map("message_type")
  subType     String    @map("sub_type")
  groupId     String?   @map("group_id")
  userId      String?   @map("user_id")
  nickname    String?
  messageId   Int?      @map("message_id")
  message     Json
  eventTime   DateTime? @map("event_time")
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([createdAt], map: "napcat_qq_message_created_at_idx")
  @@index([messageType, createdAt], map: "napcat_qq_message_message_type_created_at_idx")
  @@index([groupId, createdAt], map: "napcat_qq_message_group_id_created_at_idx")
  @@index([nickname, createdAt], map: "napcat_qq_message_nickname_created_at_idx")
  @@index([userId, createdAt], map: "napcat_qq_message_user_id_created_at_idx")
  @@map("napcat_qq_message")
}

model OauthSession {
  id            Int       @id @default(autoincrement())
  provider      String
  accountId     String?   @map("account_id")
  email         String?
  accessToken   String?   @map("access_token")
  refreshToken  String?   @map("refresh_token")
  idToken       String?   @map("id_token")
  expiresAt     DateTime? @map("expires_at")
  lastRefreshAt DateTime? @map("last_refresh_at")
  status        String
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @map("updated_at")

  @@unique([provider], map: "oauth_session_provider_uq")
  @@index([status, updatedAt], map: "oauth_session_status_updated_at_idx")
  @@map("oauth_session")
}

model OauthState {
  id           Int       @id @default(autoincrement())
  state        String    @unique(map: "oauth_state_state_uq")
  codeVerifier String    @map("code_verifier")
  redirectUri  String    @map("redirect_uri")
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([expiresAt], map: "oauth_state_expires_at_idx")
  @@map("oauth_state")
}

model AuthUsageSnapshot {
  id               Int       @id @default(autoincrement())
  provider         String
  accountId        String    @map("account_id")
  windowKey        String    @map("window_key")
  remainingPercent Float     @map("remaining_percent")
  resetAt          DateTime? @map("reset_at")
  capturedAt       DateTime  @default(now()) @map("captured_at")

  @@index([provider, accountId, capturedAt], map: "auth_usage_snapshot_provider_account_captured_at_idx")
  @@index([provider, accountId, windowKey, capturedAt], map: "auth_usage_snapshot_provider_account_window_captured_at_idx")
  @@index([capturedAt], map: "auth_usage_snapshot_captured_at_idx")
  @@map("auth_usage_snapshot")
}

model EmbeddingCache {
  id                   Int      @id @default(autoincrement())
  provider             String
  model                String
  taskType             String   @map("task_type")
  outputDimensionality Int      @map("output_dimensionality")
  text                 String
  textHash             String   @map("text_hash")
  embedding            String
  createdAt            DateTime @default(now()) @map("created_at")

  @@unique([provider, model, taskType, outputDimensionality, textHash], map: "embedding_cache_provider_model_task_output_text_hash_uq")
  @@index([createdAt], map: "embedding_cache_created_at_idx")
  @@map("embedding_cache")
}

model RootAgentRuntimeSnapshot {
  id                 Int       @id @default(autoincrement())
  runtimeKey         String    @unique(map: "root_agent_runtime_snapshot_runtime_key_uq") @map("runtime_key")
  schemaVersion      Int       @map("schema_version")
  contextSnapshot    Json      @map("context_snapshot")
  sessionSnapshot    Json      @map("session_snapshot")
  lastWakeReminderAt DateTime? @map("last_wake_reminder_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @map("updated_at")

  @@map("root_agent_runtime_snapshot")
}

model LinearMessageLedger {
  id         Int      @id @default(autoincrement())
  runtimeKey String   @map("runtime_key")
  message    Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([runtimeKey, id], map: "ledger_runtime_key_id_idx")
  @@index([createdAt], map: "ledger_created_at_idx")
  @@map("ledger")
}

model Story {
  id                    String                @id @default(uuid())
  markdown              String
  sourceMessageSeqStart Int                   @map("source_message_seq_start")
  sourceMessageSeqEnd   Int                   @map("source_message_seq_end")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @default(now()) @map("updated_at")
  memoryDocuments       StoryMemoryDocument[]

  @@index([updatedAt], map: "story_updated_at_idx")
  @@index([sourceMessageSeqEnd], map: "story_source_message_seq_end_idx")
  @@map("story")
}

model StoryMemoryDocument {
  id             Int      @id @default(autoincrement())
  storyId        String   @map("story_id")
  kind           String
  content        String
  embeddingModel String?  @map("embedding_model")
  embeddingDim   Int?     @map("embedding_dim")
  embedding      String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")
  story          Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, kind], map: "story_memory_document_story_id_kind_uq")
  @@index([storyId], map: "story_memory_document_story_id_idx")
  @@map("story_memory_document")
}

model StoryAgentRuntimeSnapshot {
  id                      Int      @id @default(autoincrement())
  runtimeKey              String   @unique(map: "story_agent_runtime_snapshot_runtime_key_uq") @map("runtime_key")
  schemaVersion           Int      @map("schema_version")
  contextSnapshot         Json     @map("context_snapshot")
  lastProcessedMessageSeq Int      @default(0) @map("last_processed_message_seq")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @default(now()) @map("updated_at")

  @@map("story_agent_runtime_snapshot")
}

// App 状态持久化能力的通用存储：一张表服务所有 App，按 appId 存一份不透明 JSON。
// 形状 + 版本由各 App 自己拥有；这里只负责 KV 式存取。
model AppState {
  appId     String   @id @map("app_id")
  state     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_state")
}

model IthomeArticle {
  id                      Int       @id @default(autoincrement())
  upstreamId              String    @unique(map: "ithome_article_upstream_id_uq") @map("upstream_id")
  title                   String
  url                     String
  publishedAt             DateTime  @map("published_at")
  rssSummary              String    @map("rss_summary")
  rssPayload              Json      @map("rss_payload")
  articleContent          String?   @map("article_content")
  articleContentStatus    String    @default("pending") @map("article_content_status")
  articleContentFetchedAt DateTime? @map("article_content_fetched_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @map("updated_at")

  @@index([publishedAt], map: "ithome_article_published_at_idx")
  @@map("ithome_article")
}

model IthomeFeedCursor {
  id                  Int      @id @default(1)
  lastSeenArticleId   Int      @map("last_seen_article_id")
  lastSeenPublishedAt DateTime @map("last_seen_published_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")

  @@map("ithome_feed_cursor")
}

model TerminalState {
  id        Int      @id @default(autoincrement())
  cwd       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("terminal_state")
}

model TerminalOutput {
  id        Int      @id @default(autoincrement())
  outputId  String   @unique(map: "terminal_output_output_id_uq") @map("output_id")
  stdout    String
  stderr    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt], map: "terminal_output_created_at_idx")
  @@map("terminal_output")
}

model TodoItem {
  id            Int       @id @default(autoincrement())
  title         String
  note          String?
  status        String    @default("pending")
  remindAt      DateTime? @map("remind_at")
  repeatEveryMs Int?      @map("repeat_every_ms")
  snoozedUntil  DateTime? @map("snoozed_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")

  @@map("todo_item")
}

// 内容寻址的图片资产登记：NapCat 图片 file_id（= 内容 MD5 + 扩展名）→ OSS resid +
// vision 描述。每张不同的图全局只下载/描述/PUT 一次，命中即复用，让 resid 跨消息稳定、
// 不膨胀；description 一并缓存，命中时连 vision 都跳过。
model ImageAsset {
  id          Int      @id @default(autoincrement())
  fileId      String   @unique(map: "image_asset_file_id_uq") @map("file_id")
  resid       String
  description String
  mime        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("image_asset")
}

// Browser App 的网站登录凭据：按 handle 存账号密码。Kagami 在 type(secretHandle) 时
// 只引用 handle，明文密码经 BrowserService 直接 fill 进输入框，永不进 tool result /
// 语义树 / 截图 / 上下文。明文存储与现有 auth secret store（encode/decode 明文透传）
// posture 一致；data/ 已 gitignore，单机自用。Kagami 运行期可自己增改（区别于 config
// 静态密钥）。
model BrowserCredential {
  id        Int      @id @default(autoincrement())
  handle    String   @unique(map: "browser_credential_handle_uq")
  username  String
  secret    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("browser_credential")
}
